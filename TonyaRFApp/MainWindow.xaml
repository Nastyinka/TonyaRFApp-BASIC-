<Window x:Class="TonyaRFApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TonyaRFApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="700" Width="1500">
    <Window.Resources>
        <!-- Colour Palette - change value here, changes everywhere-->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#C9748F"/>
        <SolidColorBrush x:Key="DarkBrush" Color="#8B4F5E"/>
        <SolidColorBrush x:Key="LavanderBrush" Color="#E8D5E8"/>
        <SolidColorBrush x:Key="MidLavBrush" Color="#9B8DB0"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#FAF6F8"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextDarkBrush" Color="#2C2C2C"/>
        <SolidColorBrush x:Key="TextLightBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#7A6B75"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#D4B8C7"/>
        <!-- Placeholder Style -->
        <Style x:Key="PlaceholderStyle" TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            <TextBlock Text="{TemplateBinding Tag}" Foreground="{StaticResource TextMutedBrush}" FontStyle="Italic" VerticalAlignment="Center" Margin="6,0,0,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <!-- This style will hide the placeholder text when the TextBox has text or is focused -->
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="Padding" Value="4.0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <!--Button Style-->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Triggers for button states -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource DarkBrush}"/>
                            </Trigger>
                            <!-- Is pressed trigger for a more press feel-->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- DataGrid Style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="RowBackground" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource LavanderBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource LavanderBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{StaticResource MidLavBrush}"/>
                        <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource LavanderBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
        <!-- Label / Textblock Style-->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
        </Style>
        <!-- Date Picker Style -->
        <Style TargetType="DatePicker">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
        </Style>
        <!-- CheckBox Style -->
        <Style TargetType="CheckBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <!-- Tab Control Style -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="Background" Value="{StaticResource LavanderBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="tabBorder" Background="{TemplateBinding Background}" BorderThickness="0" Padding="{TemplateBinding Padding}" Margin="0,0,3,0" CornerRadius="4,4,0,0">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="tabBorder" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tabBorder" Property="Background" Value="{StaticResource MidLavBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
    </Window.Resources>
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Title Bar-->
        <Border Background="{StaticResource DarkBrush}">
            <TextBlock Text="Tonya RF Client Manager"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextLightBrush}"/>
        </Border>
        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="Clients &amp; Appointments">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TabControl Grid.Row="0" Margin="0,0,0,5">
                        <TabItem Header="Basic Info">
                            <WrapPanel Margin="5,8,5,8" Orientation="Horizontal">
                                <TextBox x:Name="txtFirstName" Width="150" Margin="0,0,10,0" Height="30" Style="{StaticResource PlaceholderStyle}" Tag="First Name"/>
                                <TextBox x:Name="txtSurname" Width="150" Margin="0,0,10,0" Height="30" Style="{StaticResource PlaceholderStyle}" Tag="Surname"/>
                                <TextBox x:Name="txtPhone" Width="150" Margin="0,0,10,0" Height="30" Style="{StaticResource PlaceholderStyle}" Tag="Phone"/>
                                <StackPanel Orientation="Vertical" Margin="0,0,10,0">
                                    <TextBlock Text="Date of Birth" FontSize="10" Foreground="Gray"/>
                                    <DatePicker x:Name="dpDOB" Width="140" Height="30"/>
                                </StackPanel>

                                <TextBox x:Name="txtAddress" Width="220" Margin="0,0,10,0" Height="30" Style="{StaticResource PlaceholderStyle}" Tag="Address"/>
                            </WrapPanel>
                        </TabItem>
<!-- Medical Content Tab-->
                        <TabItem Header="Medical &amp; Consent">
                            <Grid Margin="5,8,5,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <CheckBox x:Name="chkAllergies" Content="Allergies?" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox x:Name="txtAllergyDetails" Grid.Row="0" Grid.Column="1" Height="28" Style="{StaticResource PlaceholderStyle}" Tag="Allergy Details"/>

                                <CheckBox x:Name="chkImplants" Content="Implants?" Grid.Row="0" Grid.Column="3" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtImplantDetails" Grid.Row="0" Grid.Column="4" Height="28" Style="{StaticResource PlaceholderStyle}" Tag="Implant Details"/>

                                <CheckBox x:Name="chkBotox" Content="Botox?" Grid.Row="0" Grid.Column="6" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtBotoxDetails" Grid.Row="0" Grid.Column="7" Height="28" Style="{StaticResource PlaceholderStyle}" Tag="Botox Details"/>

                                <CheckBox x:Name="chkFaceMetals" Content="Face Metals?" Grid.Row="2" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtFaceMetalDetails" Grid.Row="2" Grid.Column="1" Height="28" Style="{StaticResource PlaceholderStyle}" Tag="Metal Details"/>

                                <CheckBox x:Name="chkConsentSigned" Content="Consent Signed?" Grid.Row="2" Grid.Column="3" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Vertical" Grid.Row="2" Grid.Column="4">
                                    <TextBlock Text="Consent Date" FontSize="10" Foreground="Gray"/>
                                    <DatePicker x:Name="dpConsentDate" Width="200" Height="28"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>
                    </TabControl>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Add Client" Height="30" Width="110" Margin="0,0,8,0" Click="AddClient_Click"/>

                        <Button Content="Update Client" Width="110" Height="30" Margin="0,0,8,0" Click="UpdateClient_Click"/>

                        <Button Content="Delete Client" Width="110" Height="30" Margin="0,0,20,0" Click="DeleteClient_Click"/>

                        <TextBox x:Name="txtSearch" Width="200" Height="30" TextChanged="txtSearch_TextChanged" Style="{StaticResource PlaceholderStyle}" Tag="Search Clients...."/>
                    </StackPanel>
                    <!-- Appointment Booking -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,8">
                        <TextBlock Text="Book Appointment"
                       FontSize="16"
                       Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal">

                            <ComboBox x:Name="cbClients" Width="200" Height="30" Margin="0,0,10,0"/>
                            <ComboBox x:Name="cbTreatments" Width="200" Height="30" Margin="0,0,10,0"/>

                            <StackPanel Orientation="Vertical" Margin="0,0,10,0">
                                <TextBlock Text="Appointment Date" FontSize="10" Foreground="Gray"/>
                                <DatePicker x:Name="dpAppointmentDate" Width="150" Height="28"/>
                            </StackPanel>
                            
                            <ComboBox x:Name="cbAppointmentTime" Width="100" Height="30" Margin="0,0,10,0"/>
                            <TextBox x:Name="txtAppointmentNotes" Width="200" Height="30" Margin="0,0,10,0" Style="{StaticResource PlaceholderStyle}" Tag="Appointment Notes"/>

                            <Button Content="Book Appointment"
                        Width="150"
                        Height="30"
                 Click="BookAppointment_Click"/>

                            <Button Content="Update Appointment"
                        Width="150"
                        Height="30"
                        Margin="10,0,0,0"
                        Click="UpdateAppointment_Click"/>

                            <Button Content="Delete Appointment"
                        Width="150"
                        Height="30"
                        Margin="10,0,0,0"
                        Click="DeleteAppointment_Click"/>

                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="3">
                        <TextBlock Text="Clients" FontSize="18" Margin="0,0,0,4"/>
                        <DataGrid x:Name="dgClients"
                      Height="160"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"
                      SelectionChanged="dgClients_SelectionChanged"/>
                        <TextBlock Text="Appointments" FontSize="18" Margin="0,12,0,4"/>
                        <DataGrid x:Name="dgAppointments"
                      Height="160"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionChanged="dgAppointments_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Client" Binding="{Binding ClientName}" Width="150"/>
                                <DataGridTextColumn Header="Treatment" Binding="{Binding TreatmentName}" Width="180"/>
                                <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat=€\{0:0.00\}}" Width="75"/>
                                <DataGridTextColumn Header="Date" Binding="{Binding AppointmentDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                                <DataGridTextColumn Header="Time" Binding="{Binding AppointmentTime}" Width="80"/>
                                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Treatments">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,10">
                        <TextBox x:Name="txtTreatmentName" Width="200" Height="30" Margin="0,0,10,0" Style="{StaticResource PlaceholderStyle}" Tag="Treatment Name"/>
                        <TextBox x:Name="txtPrice" Width="100" Height="30" Margin="0,0,10,0" Style="{StaticResource PlaceholderStyle}" Tag="Price"/>
                        <TextBox x:Name="txtDurationMinutes" Width="100" Height="30" Margin="0,0,10,0" Style="{StaticResource PlaceholderStyle}" Tag="Duration (mins)"/>

                        <Button Content="Add Treatment" Width="130" Height="30" Click="AddTreatment_Click"/>
                        <Button Content="Update Treatment" Width="130" Height="30" Margin="10,0,0,0" Click="UpdateTreatment_Click"/>
                        <Button Content="Delete Treatment" Width="130" Height="30" Margin="10,0,0,0" Click="DeleteTreatment_Click"/>
                        
                    </StackPanel>
                    <DataGrid x:Name="dgTreatments" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="dgTreatments_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Treatment Name" Binding="{Binding TreatmentName}" Width="250"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="100"/>
                            <DataGridTextColumn Header="Duration (mins)" Binding="{Binding DurationMinutes}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
