<Window x:Class="TonyaRFApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TonyaRFApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="700" Width="1500">
    <Window.Resources>
        <!-- Colour Palette - change value here, changes everywhere-->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#C9748F"/>
        <SolidColorBrush x:Key="DarkBrush" Color="#8B4F5E"/>
        <SolidColorBrush x:Key="LavenderBrush" Color="#E8D5E8"/>
        <SolidColorBrush x:Key="MidLavBrush" Color="#9B8DB0"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#FAF6F8"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextDarkBrush" Color="#2C2C2C"/>
        <SolidColorBrush x:Key="TextLightBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#7A6B75"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#D4B8C7"/>
        
        <!-- GroupBox Style -->
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontWeight="SemiBold" FontFamily="Segoe UI" FontSize="13" Foreground="{StaticResource DarkBrush}"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Placeholder Style -->
        <Style x:Key="PlaceholderStyle" TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            <TextBlock Text="{TemplateBinding Tag}" Foreground="{StaticResource TextMutedBrush}" FontStyle="Italic" VerticalAlignment="Center" Margin="6,0,0,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <!-- This style will hide the placeholder text when the TextBox has text or is focused -->
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value=""/>
                                                        <Condition Binding="{Binding IsFocused, RelativeSource={RelativeSource TemplatedParent}}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="Padding" Value="4.0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <!--Button Style-->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Triggers for button states -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource DarkBrush}"/>
                            </Trigger>
                            <!-- Is pressed trigger for a more press feel-->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- DataGrid Style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="RowBackground" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource LavenderBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource LavenderBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{StaticResource MidLavBrush}"/>
                        <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource LavenderBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
        <!-- Label / Textblock Style-->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
        </Style>
        <!-- Date Picker Style -->
        <Style TargetType="DatePicker">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
        </Style>
        <!-- CheckBox Style -->
        <Style TargetType="CheckBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <!-- Tab Control Style -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="Background" Value="{StaticResource LavenderBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="tabBorder" Background="{TemplateBinding Background}" BorderThickness="0" Padding="{TemplateBinding Padding}" Margin="0,0,3,0" CornerRadius="4,4,0,0">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="tabBorder" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
    </Window.Resources>
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Title Bar-->
        <Border Background="{StaticResource DarkBrush}">
            <TextBlock Text="Tonya RF Client Manager"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextLightBrush}"/>
        </Border>
        <TabControl x:Name="mainTabControl" Grid.Row="1" Margin="10">
            <TabItem Header="Clients">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <!-- Row 0 -> search n selection grid, pick client here to edit || Row 1 -> Basic Info gb || Row 2 -> Med n consent gp || Row 3 -> buttons n total apps -->
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBox x:Name="txtSearch" Height="30" Margin="0,0,0,6" Style="{StaticResource PlaceholderStyle}" Tag="Search by name or phone...." TextChanged="txtSearch_TextChanged"/>
                        <!-- Datagrid for SELECTION ONLY-->
                        <DataGrid x:Name="dgClients" Height="120" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="dgClients_SelectionChanged" AutoGeneratingColumn="dgClients_AutoGeneratingColumn">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="First Name" Binding="{Binding FirstName}" Width="120"/>
                                <DataGridTextColumn Header="Surname" Binding="{Binding Surname}" Width="120"/>
                                <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" Width="130"/>
                                <DataGridTextColumn Header="DOB" Binding="{Binding DOB, StringFormat=dd/MM/yyyy}" Width="100"/>
                                <DataGridTextColumn Header="Appointments" Binding="{Binding TotalAppointments}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                    <!-- Basic Info GroupBox -->
                    <GroupBox Grid.Row="1" Header="Basic Information">
                        <WrapPanel Orientation="Horizontal">
                            <StackPanel Orientation="Vertical" Margin="0,0,10,6">
                                <TextBlock Text="First Name" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,2"/>
                                <TextBox x:Name="txtFirstName" Width="150" Height="30" Style="{StaticResource PlaceholderStyle}" Tag="First Name"/>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Margin="0,0,10,6">
                                <TextBlock Text="Surname" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,2"/>
                                <TextBox x:Name="txtSurname" Width="150" Height="30" Style="{StaticResource PlaceholderStyle}" Tag="Surname"/>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Margin="0,0,10,6">
                                <TextBlock Text="Phone" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,2"/>
                                <TextBox x:Name="txtPhone" Width="150" Height="30" Style="{StaticResource PlaceholderStyle}" Tag="Phone"/>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Margin="0,0,10,6">
                                <TextBlock Text="Date of Birth" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,2"/>
                                <DatePicker x:Name="dpDOB" Width="140" Height="30"/>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Margin="0,0,10,6">
                                <TextBlock Text="Address" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,2"/>
                                <TextBox x:Name="txtAddress" Width="250" Height="30" Style="{StaticResource PlaceholderStyle}" Tag="Address"/>
                            </StackPanel>
                        </WrapPanel>
                    </GroupBox>

                    <!-- Medical and Consent GroupBox -->
                    <GroupBox Grid.Row="2" Header="Medical &amp; Consent">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <CheckBox x:Name="chkAllergies" Content="Allergies" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="txtAllergyDetails" Grid.Row="0" Grid.Column="1" Height="28" Style="{StaticResource PlaceholderStyle}" Tag="Allergy Details"/>

                            <CheckBox x:Name="chkImplants" Content="Implants" Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="txtImplantDetails" Grid.Row="0" Grid.Column="4" Height="28" Style="{StaticResource PlaceholderStyle}" Tag="Implant Details"/>

                            <CheckBox x:Name="chkBotox" Content="Botox" Grid.Row="0" Grid.Column="6" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="txtBotoxDetails" Grid.Row="0" Grid.Column="7" Height="28" Style="{StaticResource PlaceholderStyle}" Tag="Botox Details"/>

                            <CheckBox x:Name="chkFaceMetals" Content="Face Metals" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="txtFaceMetalDetails" Grid.Row="2" Grid.Column="1" Height="28" Style="{StaticResource PlaceholderStyle}" Tag="Metal Details"/>

                            <CheckBox x:Name="chkConsentSigned" Content="Consent Signed" Grid.Row="2" Grid.Column="3" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <StackPanel Orientation="Vertical" Grid.Row="2" Grid.Column="4">
                                <TextBlock Text="Consent Date" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,2"/>
                                <DatePicker x:Name="dpConsentDate" Width="180" Height="28"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Content="Add Client" Height="30" Width="110" Margin="0,0,8,0" Click="AddClient_Click"/>

                        <Button Content="Update Client" Width="110" Height="30" Margin="0,0,8,0" Click="UpdateClient_Click"/>

                        <Button Content="Delete Client" Width="110" Height="30" Margin="0,0,8,0" Click="DeleteClient_Click"/>

                        <Button Content="New Client" Width="110" Height="30" Margin="0,0,20,0" Click="NewClient_Click"/>

                        <Border Background="{StaticResource LavenderBrush}" CornerRadius="4" Padding="12,0" VerticalAlignment="Center">
                            <TextBlock x:Name="txtTotalAppointments" Text="Total Appointments: -" FontWeight="SemiBold" Foreground="{StaticResource DarkBrush}" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>
            <!-- Appointments -->
            <TabItem Header="Appointments">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Booking Form -->
                        <RowDefinition Height="*"/>     <!-- Appointments Grid -->
                    </Grid.RowDefinitions>
                    <!-- Form -->
                    <GroupBox Grid.Row="0" Header="Book Appointments" Margin="0,0,0,8">
                        <WrapPanel Orientation="Horizontal">
                            <StackPanel Orientation="Vertical" Margin="0,0,10,6">
                                <TextBlock Text="Client" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,2"/>
                                <ComboBox x:Name="cbClients" Width="200" Height="30"/>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Margin="0,0,10,6">
                                <TextBlock Text="Treatment" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,2"/>
                                <ComboBox x:Name="cbTreatments" Width="200" Height="30"/>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Margin="0,0,10,6">
                                <TextBlock Text="Date" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,2"/>
                                <DatePicker x:Name="dpAppointmentDate" Width="150" Height="30"/>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Margin="0,0,10,6">
                                <TextBlock Text="Time" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,2"/>
                                <ComboBox x:Name="cbAppointmentTime" Width="100" Height="30"/>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Margin="0,0,10,6">
                                <TextBlock Text="Notes" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,2"/>
                                <TextBox x:Name="txtAppointmentNotes" Width="200" Height="30" Style="{StaticResource PlaceholderStyle}" Tag="Notes"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,6">
                                <Button Content="Book" x:Name="BookAppointmentButton" Width="80" Height="30" Margin="0,0,8,0" Click="BookAppointment_Click"/>
                                <Button Content="Update" Width="80" Height="30" Margin="0,0,8,0" Click="UpdateAppointment_Click"/>
                                <Button Content="Delete" Width="80" Height="30" Click="DeleteAppointment_Click"/>
                            </StackPanel>
                            
                        </WrapPanel>
                    </GroupBox>
                    
                    <!-- Appointment DataGrid -->
                    <StackPanel Grid.Row="1">
                        <TextBlock Text="Appointments" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource DarkBrush}" Margin="0,0,0,6"/>
                        <DataGrid x:Name="dgAppointments" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="dgAppointments_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Client" Binding="{Binding ClientName}" Width="150"/>
                                <DataGridTextColumn Header="Treatment" Binding="{Binding TreatmentName}" Width="180"/>
                                <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat=€\{0:0.00\}}" Width="80"/>
                                <DataGridTextColumn Header="Date" Binding="{Binding AppointmentDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                                <DataGridTextColumn Header="Time" Binding="{Binding AppointmentTime}" Width="80"/>
                                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                    
                </Grid>
            </TabItem>
            <!-- Records -->
            <TabItem Header="Records">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="250"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Client Records" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource DarkBrush}" Margin="0,0,0,6"/>
                        <DataGrid x:Name="dgRecordsClients" Height="200" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="dgRecordsClients_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="First Name" Binding="{Binding FirstName}" Width="120"/>
                                <DataGridTextColumn Header="Surname" Binding="{Binding Surname}" Width="120"/>
                                <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" Width="130"/>
                                <DataGridTextColumn Header="DOB" Binding="{Binding DOB, StringFormat=dd/MM/yyyy}" Width="100"/>
                                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="200"/>

                                <DataGridTextColumn Header="Total Appointments" Binding="{Binding TotalAppointments}" Width="140"/>
                                <!-- Comes from the COUNT + LEFT JOIN query-->
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                    <!-- Dynamic label updating when selected clients name -->
                    <TextBlock x:Name="txtAppointmentHistoryLabel" Grid.Row="1" Text="Appointment History - select a client above" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource DarkBrush}" Margin="0,12,0,6"/>

                    <!-- Appointment history for selected client -->
                    <DataGrid x:Name="dgClientAppointments" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding AppointmentDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                            <DataGridTextColumn Header="Time" Binding="{Binding AppointmentTime}" Width="80"/>
                            <DataGridTextColumn Header="Treatment" Binding="{Binding TreatmentName}" Width="200"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat=€\{0:0.00\}}" Width="80"/>
                            <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                </Grid>
            </TabItem>

            <TabItem Header="Treatments">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,10">
                        <TextBox x:Name="txtTreatmentName" Width="200" Height="30" Margin="0,0,10,0" Style="{StaticResource PlaceholderStyle}" Tag="Treatment Name"/>
                        <TextBox x:Name="txtPrice" Width="100" Height="30" Margin="0,0,10,0" Style="{StaticResource PlaceholderStyle}" Tag="Price"/>
                        <TextBox x:Name="txtDurationMinutes" Width="100" Height="30" Margin="0,0,10,0" Style="{StaticResource PlaceholderStyle}" Tag="Duration (mins)"/>

                        <Button Content="Add Treatment" Width="130" Height="30" Click="AddTreatment_Click"/>
                        <Button Content="Update Treatment" Width="130" Height="30" Margin="10,0,0,0" Click="UpdateTreatment_Click"/>
                        <Button Content="Delete Treatment" Width="130" Height="30" Margin="10,0,0,0" Click="DeleteTreatment_Click"/>

                    </StackPanel>
                    <DataGrid x:Name="dgTreatments" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="dgTreatments_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Treatment Name" Binding="{Binding TreatmentName}" Width="250"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="100"/>
                            <DataGridTextColumn Header="Duration (mins)" Binding="{Binding DurationMinutes}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Calander -->
            
            <TabItem Header="Calendar">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,10,0,10" VerticalAlignment="Center">
                        <Button Content="&lt; Previous Week" Width="120" Height="35" Margin="0,0,8,0" Click="PreviousWeek_Click"/>
                        <Button Content="Today" Width="70" Height="35" Margin="0,0,8,0" Click="GoToToday_Click"/>
                        <Button Content="Next Week &gt;" Width="120" Height="35" Margin="0,0,20,0" Click="NextWeek_Click"/>
                        
                        <TextBlock x:Name="txtWeekLabel" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource DarkBrush}"/>
                        
                    </StackPanel>
                    
                    <!-- Scroll view and side panel -->

                    <Grid Grid.Row="1">
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <Grid x:Name="weekGrid" Background="{StaticResource SurfaceBrush}"/>
                        </ScrollViewer>

                        <Border x:Name="sidePanel" Visibility="Collapsed" HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="280" Background="{StaticResource BackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <!-- Header -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- date/time -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- client label -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- client combo -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- treatment label -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- treatment combo -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- notes label -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- notes textbox -->
                                    <RowDefinition Height="*"/>
                                    <!-- spacer -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- buttons -->
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                    <TextBlock Text="Book Appointment" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource DarkBrush}"/>


                                    <Button Content="✕" HorizontalAlignment="Right" Width="28" Height="28" Background="Transparent" Foreground="{StaticResource TextMutedBrush}" BorderThickness="0" FontSize="14" Click="CloseSidePanel_Click"/>
                                </Grid>

                                <Border x:Name="pnlDateTimeDisplay" Grid.Row="1" Background="{StaticResource LavenderBrush}" CornerRadius="4" Padding="8,6" Margin="0,0,0,12">
                                    <TextBlock x:Name="txtPanelDateTime" FontWeight="SemiBold" Foreground="{StaticResource DarkBrush}" FontSize="13"/>
                                </Border>

                                <StackPanel x:Name="pnlDateTimeEdit" Grid.Row="1" Margin="0,0,0,12" Visibility="Collapsed">
                                    <TextBlock Text="Date" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,3"/>
                                    <DatePicker x:Name="dpPanelDate" Height="30" Margin="0,0,0,8"/>
                                    <TextBlock Text="Time" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,3"/>
                                    <ComboBox x:Name="cbPanelTime" Height="30"/>
                                </StackPanel>

                                <TextBlock Grid.Row="2" Text="Client" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,3"/>
                                <ComboBox x:Name="cbPanelClients" Grid.Row="3" Height="30" Margin="0,0,0,10"/>

                                <TextBlock Grid.Row="4" Text="Treatment" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,3"/>
                                <ComboBox x:Name="cbPanelTreatments" Grid.Row="5" Height="30" Margin="0,0,0,10"/>

                                <TextBlock Grid.Row="6" Text="Notes" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,3"/>
                                <TextBox x:Name="txtPanelNotes" Grid.Row="7" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Style="{StaticResource PlaceholderStyle}" Tag="Optional Notes..." Margin="0,0,0,10"/>

                                <Button x:Name="btnPanelBook" Grid.Row="9" Content="Book Appointment" Height="34" Margin="0,0,0,8" Visibility="Collapsed" Click="PanelBookAppointment_Click"/>

                                <Grid Grid.Row="9" x:Name="pnlEditButtons" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0" Content="Update" Height="34" Click="PanelUpdateAppointment_Click"/>
                                    
                                    <Button Grid.Column="2" Content="Delete" Height="34" Background="{StaticResource DarkBrush}" Click="PanelDeleteAppointment_Click"/>
                                </Grid>
                            </Grid>
                        </Border>

                    </Grid>
                </Grid>
            </TabItem>
            
        </TabControl>
    </Grid>
</Window>
