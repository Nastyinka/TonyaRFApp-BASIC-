<Window x:Class="TonyaRFApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TonyaRFApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="500" Width="1100">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Tonya RF Client Manager"
                   FontSize="24"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,20">

            <TextBox x:Name="txtFirstName"
                 Width="150"
                 Margin="0,0,10,0"
                 Height="30"/>

            <TextBox x:Name="txtSurname"
                 Width="150"
                 Margin="0,0,10,0"
                 Height="30"/>

            <TextBox x:Name="txtPhone"
                 Width="150"
                 Margin="0,0,10,0"
                 Height="30"/>

            <DatePicker x:Name="dpDOB"
                     Width="130"
                     Margin="10,0,0,0"
                     Height="30"/>

            <TextBox x:Name="txtAddress"
                     Width="180"
                     Margin="10,0,0,0"
                     Height="30"/>

            <CheckBox x:Name="chkAllergies"
                      Content="Allergies?"
                      Margin="10,0,0,0" Height="30"/>

            <TextBox x:Name="txtAllergyDetails"
                     Width="180"
                     Margin="10,0,0,0"
                     Height="30"/>



            <Button Content="Add Client"
                Height="30"
                Width="120"
                Click="AddClient_Click"/>

            <Button Content="Update Client"
                    Width="120"
                    Height="30"
                    Margin="10,0,0,0"
                    Click="UpdateClient_Click"/>

            <Button Content="Delete Client"
                    Width="120"
                    Height="30"
                    Margin="10,0,0,0"
                    Click="DeleteClient_Click"/>

            <TextBox x:Name="txtSearch"
                     Width="200"
                     Height="30"
                     Margin="2,0,10,0"
                     TextChanged="txtSearch_TextChanged"/>

        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Vertical"
                    Margin="0,80,0,20">
            <TextBlock Text="Book Appointment"
                       FontSize="18"
                       Margin="0,10,0,10"/>
            <StackPanel Orientation="Horizontal">

                <ComboBox x:Name="cbClients"
                          Width="200"
                          Height="20"
                          Margin="0,0,10,0"/>
                <ComboBox x:Name="cbTreatments"
                          Width="250"
                          Height="30"
                          Margin="0,0,10,0"/>

                <DatePicker 
                    x:Name="dpAppointmentDate"
                    Width="150"
                    Margin="0,0,10,0"/>
                <TextBox x:Name="txtAppointmentTime"
                         Width="100"
                         Height="30"
                         Margin="0,0,10,0"/>
                <TextBox x:Name="txtAppointmentNotes"
                         Width="200"
                         Height="30"
                         Margin="0,0,10,0"/>

                <Button Content="Book Appointment"
                        Width="150"
                        Height="30"
                 Click="BookAppointment_Click"/>
                
                <Button Content="Update Appointment"
                        Width="150"
                        Height="30"
                        Margin="10,0,0,0"
                        Click="UpdateAppointment_Click"/>

                <Button Content="Delete Appointment"
                        Width="150"
                        Height="30"
                        Margin="10,0,0,0"
                        Click="DeleteAppointment_Click"/>

            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2">
            <TextBlock Text="Clients"
                       FontSize="18"
                       Margin="0,0,0,5"/>
            <DataGrid x:Name="dgClients"
                      Height="170"
                      AutoGenerateColumns="True"
                      SelectionChanged="dgClients_SelectionChanged"/>
            <TextBlock Text="Appointments"
                       FontSize="18"
                       Margin="0,20,0,5"/>
            <DataGrid x:Name="dgAppointments"
                      Height="170"
                      AutoGenerateColumns="True"
                      SelectionChanged="dgAppointments_SelectionChanged"/>
        </StackPanel>
    </Grid>
</Window>
