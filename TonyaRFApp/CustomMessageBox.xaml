<Window x:Class="TonyaRFApp.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <!--The actual visible message box-->
    <Border Margin="20" Background="White" CornerRadius="16" MinWidth="300" MaxWidth="420">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.25" Color="#8B4F5E"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!--0 = header strip-->
                <RowDefinition Height="Auto"/> <!--1 = Icon n message-->
                <RowDefinition Height="Auto"/> <!--2 = buttons-->
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="16,16,0,0" Padding="20,14">
                <Border.Background> <!--Colours for header n stuff-->
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#E8D5E8" Offset="0"/>
                        <GradientStop Color="#E4B8D7" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!--Circular icon badge-->
                    <Border x:Name="iconCircle" Width="36" Height="36" CornerRadius="18" Background="#C9748F" Margin="0,0,12,0">
                        <!--Inside circle symbol, can change in C# based on msg-->
                        <TextBlock x:Name="txtIcon" Text="✓" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <!--Title txt, deafault message that i override in C#-->
                    <TextBlock x:Name="txtTitle" Text="Tonya RF" FontFamily="pack://application:,,,/Fonts/#DynaPuff" Foreground="#8B4F5E" VerticalAlignment="Center" FontSize="20"/>
                </StackPanel>
            </Border>
            
            <!--Msg text-->
            <TextBlock x:Name="txtMessage" Grid.Row="1" FontFamily="pack://application:,,,/Fonts/#DynaPuff" FontSize="13" Foreground="#2C2C2C" TextWrapping="Wrap" TextAlignment="Center" Margin="24,20,24,16" MaxWidth="372" LineHeight="20"/>
            
            <!--Buttons-->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20,0,20,20">
                <!--Secondary, hideable button-->
                <Border x:Name="btnCancelBorder" Margin="0,0,10,0" Visibility="Collapsed">
                    <Button x:Name="btnCancel" Content="No" Width="110" Height="36" Cursor="Hand" Click="BtnCancel_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="cancelBorder" Background="#E8D5E8" CornerRadius="18" Padding="16,0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="cancelBorder" Property="Background" Value="#D4B8C7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground>
                            <SolidColorBrush Color="#8B4F5E"/>
                        </Button.Foreground>
                        <Button.FontFamily>
                            <FontFamily>pack://application:,,,/Fonts/#DynaPuff</FontFamily>
                        </Button.FontFamily>
                        <Button.FontSize>13</Button.FontSize>
                        <Button.FontWeight>SemiBold</Button.FontWeight>
                    </Button> 
                </Border>
                <!--Primary Button-->
                <Button x:Name="btnOk" Content="OK" Width="110" Height="36" Cursor="Hand" Click="BtnOk_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="okBorder" Background="#C9748F" CornerRadius="18" Padding="16,0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="okBorder" Property="Background" Value="#8B4F5E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Foreground>
                        <SolidColorBrush Color="White"/>
                    </Button.Foreground>
                    <Button.FontFamily>
                        <FontFamily>pack://application:,,,/Fonts/#DynaPuff</FontFamily>
                    </Button.FontFamily>
                    <Button.FontSize>13</Button.FontSize>
                    <Button.FontWeight>SemiBold</Button.FontWeight>
                </Button>
            </StackPanel>
            
        </Grid>
    </Border>
</Window>
